{
  "apps": [
    {
      "key": "powershell",
      "name": "PowerShell 7",
      "order": 5,
      "strategy": "winget",
      "wingetId": "9MZ1SNWT0N5D",
      "wingetSource": "msstore",
      "wingetSkipInstalledCheck": true,
      "targetVersion": "7.6.1",
      "detect": {
        "appxName": "Microsoft.PowerShell"
      },
      "fallback": {
        "releaseRepo": "indieark/vibe-coding-setup",
        "releaseTag": "bootstrap-assets",
        "releaseAsset": "PowerShell-7.6.1-win-x64.msi",
        "installerType": "msi",
        "silentArgs": [
          "ADD_PATH=1",
          "REGISTER_MANIFEST=1",
          "USE_MU=1",
          "ENABLE_MU=1"
        ]
      }
    },
    {
      "key": "git",
      "name": "Git",
      "order": 10,
      "strategy": "winget",
      "wingetId": "Git.Git",
      "detect": {
        "command": "git",
        "args": [
          "--version"
        ],
        "regex": "git version (?<version>[0-9][0-9A-Za-z.\\-]*)",
        "registryDisplayName": "^Git$",
        "registryMatch": "regex"
      },
      "fallback": {
        "releaseRepo": "indieark/vibe-coding-setup",
        "releaseTag": "bootstrap-assets",
        "releaseAsset": "Git-2.54.0-64-bit.exe",
        "installerType": "exe",
        "silentArgs": [
          "/VERYSILENT",
          "/NORESTART",
          "/NOCANCEL",
          "/SP-"
        ]
      }
    },
    {
      "key": "nodejs",
      "name": "Node.js",
      "order": 20,
      "strategy": "winget",
      "wingetId": "OpenJS.NodeJS",
      "detect": {
        "command": "node",
        "args": [
          "--version"
        ],
        "regex": "v(?<version>[0-9][0-9A-Za-z.\\-]*)",
        "registryDisplayName": "^Node\\.js$",
        "registryMatch": "regex"
      },
      "fallback": {
        "releaseRepo": "indieark/vibe-coding-setup",
        "releaseTag": "bootstrap-assets",
        "releaseAsset": "node-v25.9.0-x64.msi",
        "installerType": "msi",
        "silentArgs": []
      }
    },
    {
      "key": "python",
      "name": "Python 3.13",
      "order": 30,
      "strategy": "winget",
      "wingetId": "Python.Python.3.13",
      "detect": {
        "command": "py",
        "args": [
          "-V"
        ],
        "regex": "Python (?<version>[0-9][0-9A-Za-z.\\-]*)"
      },
      "fallback": {
        "releaseRepo": "indieark/vibe-coding-setup",
        "releaseTag": "bootstrap-assets",
        "releaseAsset": "python-3.13.13-amd64.exe",
        "installerType": "exe",
        "silentArgs": [
          "/quiet",
          "InstallAllUsers=1",
          "PrependPath=1",
          "Include_test=0",
          "Include_launcher=1"
        ]
      }
    },
    {
      "key": "vscode",
      "name": "Visual Studio Code",
      "order": 40,
      "strategy": "winget",
      "wingetId": "Microsoft.VisualStudioCode",
      "detect": {
        "command": "code",
        "args": [
          "--version"
        ],
        "regex": "^(?<version>[0-9][0-9A-Za-z.\\-]*)$",
        "registryDisplayName": "Microsoft Visual Studio Code",
        "registryMatch": "contains"
      },
      "fallback": {
        "releaseRepo": "indieark/vibe-coding-setup",
        "releaseTag": "bootstrap-assets",
        "releaseAsset": "VSCodeUserSetup-x64-1.117.0.exe",
        "installerType": "exe",
        "silentArgs": [
          "/VERYSILENT",
          "/NORESTART",
          "/MERGETASKS=!runcode"
        ]
      }
    },
    {
      "key": "codex",
      "name": "Codex Desktop",
      "order": 50,
      "strategy": "winget",
      "wingetId": "9PLM9XGG6VKS",
      "wingetSource": "msstore",
      "wingetSkipInstalledCheck": true,
      "detect": {
        "appxName": "OpenAI.Codex"
      },
      "fallback": {
        "releaseRepo": "indieark/vibe-coding-setup",
        "releaseTag": "bootstrap-assets",
        "releaseAsset": "Codex-26.325.31654.Setup.exe",
        "installerType": "exe",
        "silentArgs": [
          "/S"
        ]
      }
    },
    {
      "key": "chatgpt",
      "name": "ChatGPT (Pake)",
      "order": 60,
      "strategy": "direct-url",
      "url": "https://github.com/tw93/Pake/releases/latest/download/ChatGPT_x64.msi",
      "detect": {
        "registryDisplayName": "ChatGPT",
        "registryMatch": "exact"
      },
      "fallback": {
        "releaseRepo": "indieark/vibe-coding-setup",
        "releaseTag": "bootstrap-assets",
        "releaseAsset": "ChatGPT_x64.msi",
        "installerType": "msi",
        "silentArgs": []
      }
    },
    {
      "key": "cc-switch",
      "name": "CC Switch",
      "order": 70,
      "strategy": "github-latest-tag",
      "repo": "farion1231/cc-switch",
      "assetTemplate": "CC-Switch-{tag}-Windows.msi",
      "detect": {
        "registryDisplayName": "CC Switch",
        "registryMatch": "exact"
      },
      "fallback": {
        "releaseRepo": "indieark/vibe-coding-setup",
        "releaseTag": "bootstrap-assets",
        "releaseAsset": "CC-Switch-v3.14.0-Windows.msi",
        "installerType": "msi",
        "silentArgs": []
      }
    },
    {
      "key": "skills-manager",
      "name": "Skills Manager",
      "order": 80,
      "strategy": "github-latest-tag",
      "repo": "xingkongliang/skills-manager",
      "assetTemplate": "skills-manager_{version}_x64_en-US.msi",
      "detect": {
        "registryDisplayName": "Skills Manager",
        "registryMatch": "exact"
      },
      "fallback": {
        "releaseRepo": "indieark/vibe-coding-setup",
        "releaseTag": "bootstrap-assets",
        "releaseAsset": "skills-manager_1.14.3_x64_en-US.msi",
        "installerType": "msi",
        "silentArgs": []
      }
    }
  ]
}
